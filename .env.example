# Telegram bot token. PHP serverdagi BOT_TOKEN bilan aynan bir xil bo‘lsin.
TELEGRAM_BOT_TOKEN=123456789:AA....

# Public app name shown in UI
NEXT_PUBLIC_APP_NAME=Case Web App

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_..._yoki_service_role_key

# Telegram admin IDs. Bir nechta bo‘lsa vergul bilan yozing.
ADMIN_IDS=123456789

# Case image upload bucket
SUPABASE_CASE_IMAGES_BUCKET=case-images

# Manual gift WEBP/WEBM upload bucket
SUPABASE_GIFT_ASSETS_BUCKET=gift-assets

# Telegram Gift Catalog media mirror bucket
SUPABASE_TELEGRAM_GIFT_BUCKET=telegram-gift-assets

# Marketplace NFT gifts, e.g. t.me/nft/SnoopDogg-232372 style gifts
# Portals Authorization header value, starts with: tma ...
PORTALS_AUTH_DATA=
# Optional: default collection filter, comma separated: Snoop Dogg,Toy Bear
PORTALS_COLLECTIONS=
# Optional custom JSON source for NFT gifts
NFT_GIFTS_JSON_URL=

# GiftAsset NFT marketplace data API
# Keyni hech qachon frontendga yozmang, faqat Vercel Environment Variables ichiga qo‘ying.
GIFTASSET_API_KEY=
# Optional: custom GiftAsset base URL
GIFTASSET_API_URL=https://api.giftasset.dev/
# Optional default collections: Snoop Dogg,Toy Bear,Lol Pop
GIFTASSET_COLLECTIONS=
# Optional receiver id for aggregator if your tariff/account requires it
GIFTASSET_RECEIVER_ID=0
